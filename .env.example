# =============================================================================
# APKScan environment configuration (copy to .env)
# Defaults encode the binding governance posture: ON-PREM, LOCAL-MODEL-FIRST,
# COMMERCIAL LLM APIs OFF BY DEFAULT (IMPLEMENTATION_RULES.md §3, NFR1).
# =============================================================================

APKSCAN_ENV=development
APKSCAN_SECRET_KEY=change-me-in-production-use-a-long-random-string

# --- Datastores ---
APKSCAN_DATABASE_URL=postgresql+psycopg2://apkscan:apkscan@postgres:5432/apkscan
APKSCAN_REDIS_URL=redis://redis:6379/0

# --- Object storage (filesystem-backed by default; S3/MinIO optional) ---
APKSCAN_STORAGE_BACKEND=filesystem
APKSCAN_STORAGE_ROOT=/var/lib/apkscan/storage
# If STORAGE_BACKEND=s3:
# APKSCAN_S3_ENDPOINT=http://minio:9000
# APKSCAN_S3_BUCKET=apkscan
# APKSCAN_S3_ACCESS_KEY=apkscan
# APKSCAN_S3_SECRET_KEY=apkscan-secret

# --- MobSF (baseline scanner + REST backbone). Keep patched >= 4.4.6. ---
APKSCAN_MOBSF_URL=http://mobsf:8000
APKSCAN_MOBSF_API_KEY=
APKSCAN_MOBSF_ENABLED=true

# --- Local LLM (Ollama). On an 8 GB GPU use the 7B fallback tier. ---
APKSCAN_LLM_BACKEND=ollama
APKSCAN_OLLAMA_URL=http://ollama:11434
# Default tier for a 24 GB GPU: qwen2.5-coder:32b-instruct-q4_K_M
# Fallback for smaller GPUs (this host, 8 GB): qwen2.5-coder:7b-instruct-q4_K_M
APKSCAN_LLM_MODEL=qwen2.5-coder:7b-instruct-q4_K_M
APKSCAN_LLM_MAX_INPUT_TOKENS=8192
APKSCAN_LLM_ENABLED=true

# --- Commercial LLM egress: OFF BY DEFAULT. Do not enable for sensitive data. ---
# Setting this to true is a governance-reviewed exception only (RISKS.md).
APKSCAN_ALLOW_COMMERCIAL_LLM=false

# --- Scoring operating point (deliberate, exposed policy choice) ---
# mode: balanced | high_recall
APKSCAN_OPERATING_MODE=balanced

# --- Dynamic analysis (Phase 2, modular). MUST stay false until governance sign-off. ---
APKSCAN_DYNAMIC_ENABLED=false
